<%- include('../partials/header') %>

<div class="admin-dashboard-wrapper">
    <div class="container-fluid">
        <div class="admin-layout">
            <!-- Sidebar -->
            <aside class="admin-sidebar">
                <div class="sidebar-user">
                    <div class="user-avatar">AD</div>
                    <div class="user-info">
                        <strong>DMIC Admin</strong>
                        <span>System Controller</span>
                    </div>
                </div>
                
                <nav class="sidebar-nav">
                    <button class="nav-item active" onclick="openTab(event, 'enquiries')">
                        <i data-lucide="inbox"></i> Enquiries
                    </button>
                    <button class="nav-item" onclick="openTab(event, 'general')">
                        <i data-lucide="settings"></i> General Settings
                    </button>
                    <button class="nav-item" onclick="openTab(event, 'hero')">
                        <i data-lucide="layout"></i> Hero & Main
                    </button>
                    <button class="nav-item" onclick="openTab(event, 'about-cms')">
                        <i data-lucide="info"></i> About & Stats
                    </button>
                    <button class="nav-item" onclick="openTab(event, 'wings-mgt')">
                        <i data-lucide="map-pin"></i> Campus Wings
                    </button>
                    <button class="nav-item" onclick="openTab(event, 'features-mgt')">
                        <i data-lucide="grid"></i> Content Blocks
                    </button>
                    <button class="nav-item" onclick="openTab(event, 'gallery-mgt')">
                        <i data-lucide="image"></i> Gallery
                    </button>
                </nav>

                <div class="sidebar-footer">
                    <a href="/logout" class="logout-btn">
                        <i data-lucide="log-out"></i> Logout Session
                    </a>
                </div>
            </aside>

            <!-- Main Content Area -->
            <main class="admin-main">
                <div class="admin-header-bar">
                    <div>
                        <span class="section-tag">Internal Portal</span>
                        <h1>Management Dashboard</h1>
                    </div>
                    <div class="header-actions">
                        <a href="/" target="_blank" class="btn-premium primary">
                            <i data-lucide="external-link"></i> Live Website
                        </a>
                    </div>
                </div>

                <% if (settings.status) { %>
                    <div class="alert alert-success animate-fade-in"><i data-lucide="check-circle"></i> <%= settings.status %></div>
                <% } %>

                <!-- Enquiries Tab -->
                <div id="enquiries" class="tab-content active">
                    <div class="dashboard-grid">
                        <div class="admin-card-glass">
                            <div class="card-header">
                                <i data-lucide="user-plus"></i>
                                <h3>Admission Requests</h3>
                            </div>
                            <div class="table-responsive">
                                <table class="premium-table">
                                    <thead>
                                        <tr><th>Student Name</th><th>Applying For</th><th>Contact Phone</th></tr>
                                    </thead>
                                    <tbody>
                                        <% if (admissions && admissions.length > 0) { %>
                                            <% admissions.forEach(adm => { %>
                                                <tr>
                                                    <td><strong><%= adm.student_name %></strong></td>
                                                    <td><span class="status-badge pending"><%= adm.apply_class %></span></td>
                                                    <td><%= adm.phone %></td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr><td colspan="3" class="no-data">No new admission requests.</td></tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="admin-card-glass">
                            <div class="card-header">
                                <i data-lucide="message-square"></i>
                                <h3>Contact Messages</h3>
                            </div>
                            <div class="table-responsive">
                                <table class="premium-table">
                                    <thead>
                                        <tr><th>From</th><th>Subject</th></tr>
                                    </thead>
                                    <tbody>
                                        <% if (messages && messages.length > 0) { %>
                                            <% messages.forEach(msg => { %>
                                                <tr>
                                                    <td><strong><%= msg.name %></strong></td>
                                                    <td><%= msg.subject %></td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr><td colspan="2" class="no-data">No messages in inbox.</td></tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- General Settings Tab -->
                <div id="general" class="tab-content">
                    <div class="admin-card-glass">
                        <h3><i data-lucide="globe"></i> Site Identity & Social</h3>
                        <form action="/admin/update-settings" method="POST" class="premium-form">
                            <div class="form-grid">
                                <div class="form-group"><label>School Full Name</label><input type="text" name="school_name" value="<%= settings.school_name %>"></div>
                                <div class="form-group"><label>School Short Name</label><input type="text" name="school_short_name" value="<%= settings.school_short_name %>"></div>
                                <div class="form-group"><label>Instagram URL</label><input type="text" name="insta_url" value="<%= settings.insta_url %>"></div>
                                <div class="form-group"><label>YouTube URL</label><input type="text" name="youtube_url" value="<%= settings.youtube_url %>"></div>
                                <div class="form-group"><label>Change Admin Password</label><input type="password" name="admin_password" value="<%= settings.admin_password %>"></div>
                            </div>
                            <button type="submit" class="btn-premium primary">Save All Changes</button>
                        </form>
                    </div>
                </div>

                <!-- Hero Section Tab -->
                <div id="hero" class="tab-content">
                    <div class="dashboard-grid">
                        <div class="admin-card-glass">
                            <h3><i data-lucide="pencil"></i> Content Management</h3>
                            <form action="/admin/update-settings" method="POST" class="premium-form">
                                <div class="form-group"><label>Hero Title</label><input type="text" name="hero_title" value="<%= settings.hero_title %>"></div>
                                <div class="form-group"><label>Hero Subtitle</label><input type="text" name="hero_subtitle" value="<%= settings.hero_subtitle %>"></div>
                                <div class="form-group"><label>Description</label><textarea name="hero_description" rows="4"><%= settings.hero_description %></textarea></div>
                                <button type="submit" class="btn-premium primary">Update Visual Text</button>
                            </form>
                        </div>
                        <div class="admin-card-glass">
                            <h3><i data-lucide="image"></i> Hero Image</h3>
                            <div class="preview-box">
                                <img src="<%= settings.hero_image %>" class="img-preview">
                                <div class="preview-overlay">Current Active Image</div>
                            </div>
                            <form action="/admin/update-image" method="POST" enctype="multipart/form-data" class="premium-form">
                                <input type="hidden" name="key" value="hero_image">
                                <div class="file-upload-styled">
                                    <input type="file" name="image" id="hero-img-input" required>
                                    <label for="hero-img-input"><i data-lucide="upload-cloud"></i> Select New Image</label>
                                </div>
                                <button type="submit" class="btn-premium primary w-full">Apply New Banner</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- About Tab -->
                <div id="about-cms" class="tab-content">
                    <div class="admin-card-glass">
                        <h3><i data-lucide="file-text"></i> About Section & Stats</h3>
                        <form action="/admin/update-settings" method="POST" class="premium-form">
                            <div class="form-group"><label>About Summary (Homepage)</label><textarea name="about_summary_desc" rows="4"><%= settings.about_summary_desc %></textarea></div>
                            <div class="form-grid">
                                <div class="form-group"><label>Principal / Director Name</label><input type="text" name="principal_name" value="<%= settings.principal_name %>"></div>
                                <div class="form-group"><label>Years of Excellence (Counter)</label><input type="number" name="stat_years" value="<%= settings.stat_years %>"></div>
                            </div>
                            <button type="submit" class="btn-premium primary">Update Section Data</button>
                        </form>
                    </div>
                </div>

                <!-- Campus Wings Tab -->
                <div id="wings-mgt" class="tab-content">
                    <div class="wings-admin-list">
                        <% wings.forEach(wing => { %>
                            <div class="admin-card-glass wing-admin-card">
                                <div class="wing-info">
                                    <div class="wing-img-container">
                                        <img src="<%= wing.image_path %>" alt="<%= wing.name %>">
                                        <form action="/admin/update-wing-image" method="POST" enctype="multipart/form-data" class="wing-img-update">
                                            <input type="hidden" name="id" value="<%= wing.id %>">
                                            <input type="file" name="image" required onchange="this.form.submit()">
                                            <div class="overlay"><i data-lucide="camera"></i> Change</div>
                                        </form>
                                    </div>
                                    <div class="wing-details">
                                        <h3><%= wing.name %></h3>
                                        <span class="location"><i data-lucide="map-pin"></i> <%= wing.subtitle %></span>
                                        <span class="contact"><i data-lucide="phone"></i> <%= wing.phone %></span>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>

                <!-- Feature Manager Tab -->
                <div id="features-mgt" class="tab-content">
                    <div class="admin-card-glass feature-add-box">
                        <h3><i data-lucide="plus-circle"></i> Add New Dynamic Block</h3>
                        <form action="/admin/manage-feature" method="POST" enctype="multipart/form-data" class="premium-form">
                            <input type="hidden" name="action" value="add">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Section Category</label>
                                    <select name="section">
                                        <option value="why_choose_us">Why Choose Us (Homepage Grid)</option>
                                        <option value="achievements">Events & Highlights (Homepage Wings)</option>
                                    </select>
                                </div>
                                <div class="form-group"><label>Block Title</label><input type="text" name="title" required></div>
                                <div class="form-group"><label>Content Description</label><input type="text" name="description"></div>
                                <div class="form-group"><label>Lucide Icon Name</label><input type="text" name="icon" value="star"></div>
                                <div class="form-group" style="grid-column: span 2;"><label>Optional Illustration</label><input type="file" name="image"></div>
                            </div>
                            <button type="submit" class="btn-premium primary">Publish Block</button>
                        </form>
                    </div>

                    <h2 class="sub-section-title">Established Content Cards</h2>
                    <div class="dashboard-grid">
                        <% if (features && features.length > 0) { %>
                            <% features.forEach(feat => { %>
                                <div class="admin-card-glass feature-mgt-card">
                                    <form action="/admin/manage-feature" method="POST" enctype="multipart/form-data" class="premium-form">
                                        <input type="hidden" name="action" value="update">
                                        <input type="hidden" name="id" value="<%= feat.id %>">
                                        
                                        <div class="feat-status"><%= feat.section === 'why_choose_us' ? 'Feature' : 'Event' %></div>
                                        <div class="form-group"><label>Title</label><input type="text" name="title" value="<%= feat.title %>"></div>
                                        <div class="form-group"><label>Description</label><textarea name="description" rows="2"><%= feat.description %></textarea></div>
                                        <div class="form-group"><label>Icon Name</label><input type="text" name="icon" value="<%= feat.icon %>"></div>
                                        
                                        <% if (feat.image_path) { %>
                                            <div class="feat-current-img">
                                                <img src="<%= feat.image_path %>">
                                            </div>
                                        <% } %>
                                        <div class="form-group"><label>Replacement Image</label><input type="file" name="image" class="small-input"></div>
                                        
                                        <div class="card-actions">
                                            <button type="submit" class="btn-action update"><i data-lucide="refresh-cw"></i> Update</button>
                                            <button type="button" class="btn-action delete" onclick="confirmDelete('<%= feat.id %>')"><i data-lucide="trash-2"></i> Delete</button>
                                        </div>
                                    </form>
                                    <form id="delete-form-<%= feat.id %>" action="/admin/manage-feature" method="POST" style="display: none;">
                                        <input type="hidden" name="action" value="delete">
                                        <input type="hidden" name="id" value="<%= feat.id %>">
                                    </form>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
                <!-- Gallery Management Tab -->
                <div id="gallery-mgt" class="tab-content">
                    <div class="admin-card-glass feature-add-box">
                        <h3><i data-lucide="upload-cloud"></i> Upload Campus Memories</h3>
                        <form action="/admin/manage-gallery" method="POST" enctype="multipart/form-data" class="premium-form">
                            <input type="hidden" name="action" value="add">
                            <div class="form-grid">
                                <div class="form-group"><label>Image Title (Optional)</label><input type="text" name="title" placeholder="School Fest 2026"></div>
                                <div class="form-group">
                                    <label>Event Category</label>
                                    <select name="category">
                                        <% categories.forEach(cat => { %>
                                            <option value="<%= cat.name %>"><%= cat.name %></option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="form-group" style="grid-column: span 2;">
                                    <label>Select High Quality Images (Multiple allowed)</label>
                                    <input type="file" name="images" multiple required>
                                </div>
                            </div>
                            <button type="submit" class="btn-premium primary">Upload to Gallery</button>
                        </form>
                    </div>

                    <h2 class="sub-section-title">Current Gallery Collection</h2>
                    <div class="dashboard-grid">
                        <% if (gallery && gallery.length > 0) { %>
                            <% gallery.forEach(item => { %>
                                <div class="admin-card-glass gallery-mgt-card">
                                    <div class="gallery-preview">
                                        <img src="<%= item.image_path %>" alt="<%= item.title %>">
                                    </div>
                                    <div class="gallery-info">
                                        <h4><%= item.title %></h4>
                                        <span><%= item.category %></span>
                                    </div>
                                    <div class="card-actions">
                                        <form action="/admin/delete-gallery" method="POST" onsubmit="return confirm('Delete this memory?')">
                                            <input type="hidden" name="id" value="<%= item.id %>">
                                            <button type="submit" class="btn-action delete"><i data-lucide="trash-2"></i> Remove</button>
                                        </form>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="no-data">No images uploaded yet.</p>
                        <% } %>
                    </div>
                </div>
            </main>
        </div>
    </div>
</div>

<style>
    /* Admin Layout Styles */
    .admin-dashboard-wrapper {
        min-height: 100vh;
        background: #f0f2f5;
        padding-top: 80px;
    }
    .admin-layout {
        display: flex;
        gap: 2rem;
        padding: 2rem 0;
    }
    
    /* Sidebar */
    .admin-sidebar {
        width: 300px;
        background: var(--white);
        border-radius: 30px;
        padding: 2rem;
        box-shadow: var(--shadow-soft);
        height: fit-content;
        position: sticky;
        top: 100px;
    }
    .sidebar-user {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 3rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #f0f0f0;
    }
    .user-avatar {
        width: 50px;
        height: 50px;
        background: var(--primary);
        color: var(--white);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
    }
    .user-info strong { display: block; font-size: 1.1rem; }
    .user-info span { font-size: 0.8rem; color: #888; }
    
    .sidebar-nav { display: flex; flex-direction: column; gap: 0.5rem; }
    .nav-item {
        padding: 1rem 1.5rem;
        border: none;
        background: none;
        border-radius: 12px;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-weight: 600;
        color: #666;
        cursor: pointer;
        transition: all 0.3s;
    }
    .nav-item i { width: 20px; }
    .nav-item:hover { background: #f8f9fa; color: var(--primary); }
    .nav-item.active { background: var(--primary); color: var(--white); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
    
    .sidebar-footer { margin-top: 3rem; }
    .logout-btn {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        color: #ff4d4d;
        text-decoration: none;
        font-weight: 700;
        padding: 1rem;
        border-radius: 12px;
        transition: all 0.3s;
    }
    .logout-btn:hover { background: #fff5f5; }
    
    /* Main Content */
    .admin-main { flex: 1; }
    .admin-header-bar {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 3rem;
    }
    .admin-header-bar h1 { font-size: 2.5rem; margin-top: 0.5rem; }
    
    .dashboard-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
    .card-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; border-bottom: 2px solid #f0f0f0; padding-bottom: 1rem; }
    .card-header i { color: var(--accent-dark); }
    
    .table-responsive { overflow-x: auto; }
    .premium-table { width: 100%; border-collapse: collapse; }
    .premium-table th { text-align: left; padding: 1rem; color: #888; font-size: 0.8rem; text-transform: uppercase; border-bottom: 2px solid #f0f0f0; }
    .premium-table td { padding: 1.2rem 1rem; border-bottom: 1px solid #f0f0f0; }
    
    .premium-form .form-group { margin-bottom: 1.5rem; }
    .premium-form .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .premium-form label { display: block; margin-bottom: 0.5rem; font-weight: 700; font-size: 0.9rem; }
    .premium-form input, .premium-form select, .premium-form textarea {
        width: 100%; padding: 1rem; border: 1px solid #eee; border-radius: 12px; background: #fafafa; font-family: inherit;
    }
    .premium-form input:focus { outline: none; border-color: var(--accent); background: var(--white); }
    
    .preview-box { position: relative; border-radius: 15px; overflow: hidden; margin-bottom: 1.5rem; height: 200px; }
    .img-preview { width: 100%; height: 100%; object-fit: cover; }
    .preview-overlay { position: absolute; bottom: 0; left: 0; width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.5); color: white; text-align: center; font-size: 0.8rem; }
    
    .file-upload-styled input { display: none; }
    .file-upload-styled label { 
        display: block; padding: 1.5rem; border: 2px dashed #ddd; border-radius: 15px; text-align: center; 
        cursor: pointer; color: #888; transition: all 0.3s;
    }
    .file-upload-styled label:hover { border-color:  var(--accent); background: #fdfdfd; color: var(--primary); }
    
    .wings-admin-list { display: flex; flex-direction: column; gap: 1.5rem; }
    .wing-admin-card .wing-info { display: flex; gap: 2rem; align-items: center; }
    .wing-img-container { position: relative; width: 180px; height: 120px; border-radius: 15px; overflow: hidden; }
    .wing-img-container img { width: 100%; height: 100%; object-fit: cover; }
    .wing-img-update { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; transition: 0.3s; }
    .wing-img-container:hover .wing-img-update { opacity: 1; background: rgba(0,0,0,0.4); }
    .wing-img-update .overlay { color: white; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; }
    .wing-details h3 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .wing-details .location, .wing-details .contact { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; color: #666; margin-bottom: 0.3rem; }
    
    .feature-mgt-card { position: relative; }
    .feat-status { position: absolute; top: 1.5rem; right: 1.5rem; padding: 0.3rem 0.8rem; background: var(--bg-light); border-radius: 5px; font-size: 0.7rem; font-weight: 800; }
    .feat-current-img img { width: 100%; height: 100px; object-fit: cover; border-radius: 10px; margin-bottom: 1rem; }
    .card-actions { display: flex; gap: 1rem; margin-top: 1.5rem; }
    .btn-action { flex: 1; padding: 0.8rem; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem; transition: 0.3s; }
    .btn-action.update { background: #e3f2fd; color: #1976d2; }
    .btn-action.delete { background: #ffebee; color: #d32f2f; }
    .btn-action:hover { opacity: 0.8; transform: translateY(-2px); }

    .gallery-mgt-card { padding: 1.5rem; }
    .gallery-preview { width: 100%; height: 150px; border-radius: 12px; overflow: hidden; margin-bottom: 1rem; }
    .gallery-preview img { width: 100%; height: 100%; object-fit: cover; }
    .gallery-info h4 { margin: 0; font-size: 1rem; }
    .gallery-info span { font-size: 0.75rem; color: #888; }

    .sub-page { padding: 0; }
    header { background: var(--white) !important; position: static; box-shadow: none; border-bottom: 1px solid #f0f0f0; }
    
    .tab-content { display: none; animation: slideIn 0.5s ease; }
    .tab-content.active { display: block; }
    
    @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
</style>

<script>
    function openTab(evt, tabName) {
        var i, tabcontent, navitems;
        tabcontent = document.getElementsByClassName("tab-content");
        for (i = 0; i < tabcontent.length; i++) { tabcontent[i].classList.remove("active"); }
        navitems = document.getElementsByClassName("nav-item");
        for (i = 0; i < navitems.length; i++) { navitems[i].classList.remove("active"); }
        document.getElementById(tabName).classList.add("active");
        evt.currentTarget.classList.add("active");
    }

    function confirmDelete(id) {
        if(confirm('Are you sure you want to delete this content block? This cannot be undone.')) {
            document.getElementById('delete-form-' + id).submit();
        }
    }

    window.onload = function() {
        const urlParams = new URLSearchParams(window.location.search);
        const status = urlParams.get('status');
        if (status === 'deleted' || status === 'added') {
            const galleryBtn = document.querySelector('button[onclick*="gallery-mgt"]');
            if (galleryBtn) {
                openTab({ currentTarget: galleryBtn }, 'gallery-mgt');
            }
        }
    }
</script>

<%- include('../partials/footer') %>
